{
  "manifest_version": 3,
  "name": "castmd",
  "version": "1.3.0",
  "description": "Cast any page. Feed any model. Converts webpages to clean Markdown for LLM workflows.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "tabs"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "include_globs": ["*.md", "*.MD", "*.markdown", "*.mdown", "*.mkd"],
      "js": ["lib/markdown-to-html.js", "md-viewer.js"],
      "css": ["md-viewer.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "copy-markdown": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Copy page as Markdown"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
