{
  "manifest_version": 3,
  "name": "md·convert",
  "version": "2.0",
  "description": "Convert any webpage to clean Markdown. Built for LLM workflows.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "tabs"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "copy-markdown": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Copy page as Markdown"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
